# Postgres connection string used by the backend.
# For Docker compose the host is `db`; for local dev use `localhost`.
DATABASE_URL=postgresql+psycopg://cx:cx@localhost:5432/cx

# Which LLM implementation to use: "mock", "openai", or "anthropic".
# Keep this on "mock" unless you've set an API key.
LLM_PROVIDER=mock

# Required only when LLM_PROVIDER is "openai" or "anthropic".
LLM_API_KEY=

# Comma-separated list of origins allowed to call the API from the browser.
CORS_ORIGINS=http://localhost:5173
